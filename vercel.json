{
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/", "destination": "/admin/index.html" },
    { "source": "/cancel", "destination": "/cancel/index.html" },
    { "source": "/cancel/", "destination": "/cancel/index.html" }
  ],
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
